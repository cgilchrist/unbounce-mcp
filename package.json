{
  "name": "unbounce-mcp",
  "version": "0.1.0",
  "description": "MCP server for publishing landing pages to Unbounce — no UI required",
  "type": "module",
  "bin": {
    "unbounce-mcp": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "node --test test/unit/*.test.js",
    "test:smoke": "node --test --test-concurrency=1 test/smoke/*.test.js",
    "mcp": "node test/run.js",
    "login": "node test/harness/login.js",
    "clean-sandbox": "node test/harness/clean-sandbox.js"
  },
  "files": [
    "index.js",
    "src/",
    "switch-mcp.js",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "form-data": "^4.0.1",
    "playwright": "^1.40.0",
    "tar": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
